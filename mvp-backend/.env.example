# LLM Provider to use: "anthropic" | "openai"
LLM_PROVIDER=anthropic

# Anthropic API key (required when LLM_PROVIDER=anthropic)
# Use a key from https://console.anthropic.com (typically sk-ant-api03-...).
# Do NOT use Claude Code setup tokens (sk-ant-oat-...) — they return 400 for this API.
ANTHROPIC_API_KEY=sk-ant-api03-...

# OpenAI API key (required when LLM_PROVIDER=openai)
# OPENAI_API_KEY=sk-...

# Server port (optional, defaults to 3001)
PORT=3001

# Frontend origin allowed by CORS (optional, defaults to http://localhost:3000)
FRONTEND_ORIGIN=http://localhost:3000
