# LLM Provider to use: "anthropic" | "openai"
LLM_PROVIDER=anthropic

# Anthropic API key (required when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API key (required when LLM_PROVIDER=openai)
# OPENAI_API_KEY=sk-...

# Server port (optional, defaults to 3001)
PORT=3001

# Frontend origin allowed by CORS (optional, defaults to http://localhost:3000)
FRONTEND_ORIGIN=http://localhost:3000
